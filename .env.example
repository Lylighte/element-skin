ELEMENT_SKIN_IMAGE=ghcr.io/water2004/element-skin:latest

VITE_BASE_PATH=/
VITE_API_BASE=/skinapi

JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_DAYS=7
JWT_ACCESS_EXPIRE_MINUTES=30

KEYS_PRIVATE_KEY=/app/data/private.pem
KEYS_PUBLIC_KEY=/app/data/public.pem

DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=elementskin
DATABASE_PASSWORD=change-me
DATABASE_NAME=elementskin
DATABASE_SSLMODE=disable
DATABASE_MAX_CONNECTIONS=20

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DB=0
REDIS_KEY_PREFIX=elementskin:
REDIS_PUBLIC_CACHE_TTL_SECONDS=60
REDIS_AUTH_CACHE_TTL_SECONDS=30

TEXTURES_DIRECTORY=/app/frontend/static/textures
CAROUSEL_DIRECTORY=/app/frontend/static/carousel

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_SITE_URL=https://example.com
SERVER_API_URL=https://example.com/skinapi

CORS_ALLOW_ORIGINS=https://example.com
CORS_ALLOW_CREDENTIALS=true

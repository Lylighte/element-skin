# union-svc example configuration.
# Copy to config.yaml and adjust for your environment.
# All fields shown as empty ("") are REQUIRED and must be provided.

server:
  addr: ""
  port: 8001

elementskin:
  base_url: ""
  oauth:
    client_id: ""
    client_secret: ""
    redirect_uri: ""
  service_account:
    client_id: ""
    client_secret: ""
    scope: "profile.read.any"

storage:
  path: "./union-svc.db"

union:
  hub_url: ""
  member_key: ""
  cors_allow_origin: ""
  timeout_seconds: 30

tls:
  insecure_skip_verify: false
  ca_file: ""

log:
  level: "info"
